# Frankenstein — Environment Variables
# Copy this to .env and fill in your keys

# AI Provider: "anthropic" or "openai"
FRANKENSTEIN_PROVIDER=anthropic

# Model override (optional — defaults to claude-sonnet-4-20250514 or gpt-4o)
# FRANKENSTEIN_MODEL=claude-sonnet-4-20250514

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Day override (optional — auto-increments from App.jsx if not set)
# FRANKENSTEIN_DAY=1
